@model SmhiVader.Models.WeatherViewModel

@{
    ViewData["Title"] = "Kläder Efter Väder";
}

<div class="header">
    <h1>Vad ska<br /><span>barnen ha på sig?</span></h1>
    <p>🌍 Väder från SMHI · Klädråd för barn i förskoleåldern</p>
</div>

<!-- GPS-kort -->
<div class="card">
    <button class="btn-gps" onclick="getLocation()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3" />
            <path d="M12 2v3M12 19v3M2 12h3M19 12h3" />
            <path d="M12 8a4 4 0 1 1 0 8 4 4 0 0 1 0-8z" />
        </svg>
        Hämta min position
    </button>

    <div class="loading" id="loading">
        <div class="spinner"></div>
        Hämtar väder från SMHI…
    </div>

    @if (Model.HasError)
    {
        <div class="error-box" style="margin-top:16px">⚠️ @Model.ErrorMessage</div>
    }
</div>

<!-- Resultat  -->
@if (Model.HasResult)
{
    <div class="result-card"
         style="background: linear-gradient(145deg, @Model.Advice!.BgColor, @Model.Advice.AccentColor)">

        <div class="weather-row">
            <div class="weather-chip">
                <div class="chip-lbl">Genomsnittlig temperatur idag</div>
                <div class="chip-val-row">
                    <div class="chip-val">@Model.Temperature!.Value.ToString("F1")°</div>
                    <button class="info-btn" onclick="toggleInfo()" aria-label="Mer information">ℹ️</button>
                </div>
                <div class="info-popup" id="infoPopup">
                    Beräknat snitt baserat på SMHI:s timvisa prognoser mellan kl 06–15 för dagens datum.
                </div>
            </div>
            <div class="weather-chip">
                <div class="chip-lbl">mm/h nederbörd</div>
                <div class="chip-val">@((Model.Precipitation ?? 0).ToString("F1"))</div>
            </div>
        </div>

        <div class="advice-icon">@Model.Advice.Icon</div>
        <div class="advice-title">@Model.Advice.Title</div>
        <div class="advice-desc">@Model.Advice.Description</div>
    </div>

    <p class="coord-tag">📍 Lat: @Model.Lat?.ToString("F4") · Lon: @Model.Lon?.ToString("F4")</p>
}

<!-- Klädguide -->
<div class="card" style="margin-top:8px">
    <div class="guide-title">🧒 Snabb klädguide</div>
    <div class="guide-grid">
        <div class="guide-item"><span>❄️</span><span>Under -15° Vinteroverall, fleece, underställ </span></div>
        <div class="guide-item"><span>🧥</span><span>-15 till -5° Vinteroverall, fleece</span></div>
        <div class="guide-item"><span>🧣</span><span>-5 till 0° Vinteroverall </span></div>
        <div class="guide-item"><span>🧤</span><span>0–5° Skalset + fleece, fodrad mössa</span></div>
        <div class="guide-item"><span>🧦</span><span>5–10° Skalset + fleece, tunn mössa </span></div>
        <div class="guide-item"><span>🍃</span><span>10–15° Skaljacka, ev fleece och väst</span></div>
        <div class="guide-item"><span>☀️</span><span>15–20° Vindfleece</span></div>
    
    </div>
</div>

<footer>Data från SMHI Open Data · Uppdateras per position</footer>

@section Scripts {
    <script>
        function getLocation() {
            if (!navigator.geolocation) {
                alert("Din webbläsare stöder inte GPS.");
                return;
            }
            document.getElementById("loading").style.display = "block";
            document.querySelector(".btn-gps").disabled = true;

            navigator.geolocation.getCurrentPosition(
                pos => {
                    const lat = pos.coords.latitude.toFixed(6);
                    const lon = pos.coords.longitude.toFixed(6);
                    window.location.href = `/?lat=${lat}&lon=${lon}`;
                },
                err => {
                    document.getElementById("loading").style.display = "none";
                    document.querySelector(".btn-gps").disabled = false;
                    alert("Kunde inte hämta position: " + err.message);
                },
                { enableHighAccuracy: true, timeout: 10000 }
            );
        }


                function toggleInfo() {
            const popup = document.getElementById("infoPopup");
            popup.classList.toggle("visible");
        }

        document.addEventListener("click", function(e) {
            if (!e.target.closest(".info-btn") && !e.target.closest(".info-popup")) {
                document.getElementById("infoPopup")?.classList.remove("visible");
            }
        });


    </script>
}
